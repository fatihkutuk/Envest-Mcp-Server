## Instance-local environment variables -- DO NOT commit real secrets to repo (placeholder only).
## After copying, fill in this file; Git should not commit .env files.

MCP_ADMIN_SECRET=change-me
MCP_TOKEN_SECRET=change-me-too

# Database (used alongside instance.yaml db: block; keep passwords here)
DB_USERNAME=change-me
DB_PASSWORD=change-me

# Optional: override host/port from instance.yaml (see config KORUBIN_DB_*)
# KORUBIN_DB_HOST=127.0.0.1
# KORUBIN_DB_PORT=3306
