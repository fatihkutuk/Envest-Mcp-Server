# ============================================
# Envest MCP Server - Global Environment
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# --- Domain ---
DOMAIN=mcp.envest.com.tr

# --- SSL Mode ---
# "cloudflare" veya "letsencrypt"
SSL_MODE=cloudflare

# Cloudflare Origin Certificate (SSL_MODE=cloudflare ise)
# certs/ dizinine yerleştirin
CF_ORIGIN_CERT=certs/origin.pem
CF_ORIGIN_KEY=certs/origin.key

# Let's Encrypt (SSL_MODE=letsencrypt ise)
LETSENCRYPT_EMAIL=admin@envest.com.tr

# --- SCADA MCP ---
SCADA_MCP_PORT=8001

# --- KoruCAPS MCP ---
KORUCAPS_MCP_PORT=8002
